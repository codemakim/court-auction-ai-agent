# Court Auction AI Agent example configuration
# Copy to .env for local manual runs. Do not commit .env.

AUCTION_AI_CRAWLER_DB_PATH=/var/lib/court-auction-collector/data/court_auction.sqlite3
AUCTION_AI_DB_PATH=/var/lib/court-auction-ai-agent/data/auction_ai.sqlite3
AUCTION_AI_OLLAMA_BASE_URL=http://127.0.0.1:11434
AUCTION_AI_OLLAMA_MODEL=gemma4:e4b
AUCTION_AI_OLLAMA_TIMEOUT_SECONDS=900
AUCTION_AI_WORKER_INTERVAL_SECONDS=5
AUCTION_AI_MAX_ATTEMPTS=3
AUCTION_AI_PROMPT_VERSION=investment-risk-v1
AUCTION_AI_SCHEMA_VERSION=investment-risk-v1
